{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the AI terminal.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "A generated project or file by the AI.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["building", "completed", "error"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "content", "status", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A terminal log or chat message.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "ai", "system"] },
        "text": { "type": "string" },
        "imageUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "text", "createdAt"]
    },
    "UserData": {
      "title": "UserData",
      "description": "Arbitrary user data stored by the AI.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "key": { "type": "string" },
        "data": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "key", "data", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Stores generated projects and files."
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Stores terminal chat history."
    },
    "/user_data/{docId}": {
      "schema": { "$ref": "#/entities/UserData" },
      "description": "Stores arbitrary user data."
    }
  }
}
